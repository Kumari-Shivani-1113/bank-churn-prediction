    "print(f\"True Negatives:  {TN}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save the best model to Google Drive\n",
    "from joblib import dump\n",
    "\n",
    "model_path = '/content/drive/My Drive/BankChurner/best_rf_classifier.joblib'\n",
